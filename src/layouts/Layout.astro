---
interface Props {
	title?: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ?? 'Reactor Model of Computation'}</title>
	</head>
	<body>
		<header class="site-nav">
			<nav class="site-nav-inner">
				<a href="/" class="site-nav-logo">Reactor Model</a>
				<ul class="site-nav-links">
					<li><a href="/" class="site-nav-link">Home</a></li>
					<li><a href="/events/" class="site-nav-link">Events</a></li>
				</ul>
			</nav>
		</header>
		<main class="site-main">
			<slot />
		</main>
		<script is:inline>
			(function() {
				const path = window.location.pathname.replace(/\/$/, '') || '';
				document.querySelectorAll('.site-nav-link').forEach(function(a) {
					const href = (a.getAttribute('href') || '/').replace(/\/$/, '') || '';
					const isHome = href === '';
					const active = isHome ? path === '' : path.startsWith(href);
					if (active) a.classList.add('site-nav-active');
				});
			})();
		</script>
	</body>
</html>

<style>
	html {
		scroll-behavior: smooth;
	}
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
	.site-nav {
		position: sticky;
		top: 0;
		z-index: 100;
		background: #fff;
		border-bottom: 1px solid #e5e7eb;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}
	.site-nav-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}
	.site-nav-logo {
		font-weight: 600;
		font-size: 1.1rem;
		color: #111827;
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.site-nav-logo:hover {
		color: #6366f1;
	}
	.site-nav-links {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 0.5rem;
	}
	.site-nav-link {
		display: block;
		padding: 0.5rem 0.75rem;
		color: #4b5563;
		text-decoration: none;
		font-size: 0.95rem;
		border-radius: 0.375rem;
	}
	.site-nav-link:hover {
		color: #111827;
		background: #f3f4f6;
	}
	.site-nav-link.site-nav-active {
		color: #6366f1;
		font-weight: 500;
		background: #eef2ff;
	}
	.site-main {
		min-height: calc(100vh - 52px);
	}
	@media (prefers-color-scheme: dark) {
		.site-nav {
			background: #0f172a;
			border-color: #1e293b;
		}
		.site-nav-logo { color: #e5e7eb; }
		.site-nav-logo:hover { color: #a5b4fc; }
		.site-nav-link { color: #9ca3af; }
		.site-nav-link:hover { color: #e5e7eb; background: #1e293b; }
		.site-nav-link.site-nav-active { color: #a5b4fc; background: #1e3a5f; }
	}
</style>
